function hexToRgb(hex){
return[parseInt(hex.slice(1,3),16),parseInt(hex.slice(3,5),16),parseInt(hex.slice(5,7),16)];
}
function rgbToHex(r,g,b){
return'#'+[r,g,b].map(v=>Math.round(Math.max(0,Math.min(255,v))).toString(16).padStart(2,'0')).join('');
}
function blendHex(hex1,hex2,t){
const[r1,g1,b1]=hexToRgb(hex1);
const[r2,g2,b2]=hexToRgb(hex2);
return rgbToHex(r1+(r2-r1)*t,g1+(g2-g1)*t,b1+(b2-b1)*t);
}

function calcOhaeng(y,m,d,kstHour){
const sO=['목','목','화','화','토','토','금','금','수','수'];
const bO=['수','토','목','목','토','화','화','토','금','금','토','수'];
const mO=['목','목','화','화','토','토','금','금','수','수','목','목'];
const dM=['목','화','토','금','수'];
const hourBranch=['수','토','목','목','토','화','화','토','금','금','토','수'];
const ys=sO[((y-4)%10+10)%10];
const yb=bO[((y-4)%12+12)%12];
const mo=mO[(m-1)%12];
const dy=dM[d%5];
const counts={};ORDER.forEach(o=>counts[o]=0);
const pillars=[ys,yb,mo,dy];
if(kstHour!==null&&kstHour!==undefined){
const hIdx=Math.floor(((kstHour+1)%24)/2);
pillars.push(hourBranch[hIdx]);
}
pillars.forEach(x=>counts[x]++);
const total=pillars.length;
const sorted=ORDER.slice().sort((a,b)=>counts[b]-counts[a]);
return{counts,strong:sorted[0],weak:sorted[sorted.length-1],total};
}

function doAnalysis(){
const name=document.getElementById('nameIn').value.trim()||'당신';
let y=parseInt(document.getElementById('yIn').value);
let m=parseInt(document.getElementById('mIn').value);
let d=parseInt(document.getElementById('dIn').value);
const noTime=document.getElementById('noTimeChk').checked;
const hRaw=document.getElementById('hIn').value;
const minRaw=document.getElementById('minIn').value;
const tz=document.getElementById('tzIn').value;
const err=document.getElementById('errMsg');
if(isNaN(y)||isNaN(m)||isNaN(d)||y<1900||y>2099||m<1||m>12||d<1||d>31){
err.style.display='block';err.textContent='생년월일을 올바르게 입력해주세요.';return;
}
err.style.display='none';
let kstHour=null;
if(!noTime&&hRaw!==''&&!isNaN(parseInt(hRaw))){
const h=parseInt(hRaw);
const min=parseInt(minRaw)||0;
if(h<0||h>23){err.style.display='block';err.textContent='시간은 0~23 사이로 입력해주세요.';return;}
try{
const padded=`${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}T${String(h).padStart(2,'0')}:${String(min).padStart(2,'0')}:00`;
const localStr=new Date(padded).toLocaleString('en-CA',{timeZone:tz,hour12:false});
const utcStr=new Date(padded).toLocaleString('en-CA',{timeZone:'UTC',hour12:false});
const offsetMs=new Date(localStr)-new Date(utcStr);
const utcMs=new Date(padded).getTime()-offsetMs;
const kstDate=new Date(utcMs+9*3600*1000);
y=kstDate.getUTCFullYear();m=kstDate.getUTCMonth()+1;d=kstDate.getUTCDate();kstHour=kstDate.getUTCHours();
}catch(e){kstHour=null;}
}
const r=calcOhaeng(y,m,d,kstHour);
G={...G,name,strong:r.strong,weak:r.weak,counts:r.counts,total:r.total,usedTime:kstHour!==null};
G.selColor=OH[r.weak].palette[0];
showScreen('s-load1');
const msgs=['기운을 분석하는 중...','오방색을 배열하는 중...','수호신을 소환하는 중...'];
let mi=0;const lt=document.getElementById('loadTxt1');
const iv=setInterval(()=>{mi=(mi+1)%msgs.length;if(lt)lt.textContent=msgs[mi];},700);
setTimeout(()=>{clearInterval(iv);buildResult();showScreen('s-result');},2600);
}

