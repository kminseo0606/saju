function buildPalette(){
const s=OH[G.strong];
const w=OH[G.weak];
document.getElementById('paletteTitleTxt').textContent=`${G.strong}(${s.korColor}) · ${G.weak}(${w.korColor}) — 오행의 균형`;

// 강한 색 2장 / 중간 혼합 단색 1장 / 약한 색 2장
const midColor=blendHex(s.palette[0],w.palette[0],0.5);

G.currentDisplayPalette=[
  {color:s.palette[0], desc:`${G.strong} 대표색`, type:'strong'},
  {color:s.palette[1], desc:`${G.strong} 보조색`, type:'strong'},
  {color:midColor,     desc:`균형 · 두 기운의 중간색`, type:'blend'},
  {color:w.palette[0], desc:`${G.weak} 대표색`, type:'weak'},
  {color:w.palette[1], desc:`${G.weak} 보조색`, type:'weak'}
];

G.selPalIdx=2;
G.selColor=midColor;
document.getElementById('deckArea').innerHTML='';
}

let dealDone=false;
function dealCards(){
if(dealDone)return;dealDone=true;
const area=document.getElementById('deckArea');
area.innerHTML='';
const N=5;const CW=110;const CH=168;
const finalX=[-224,-112,0,112,224];
const angles=[-22,-11,0,11,22];
const cards=[];

for(let i=0;i<N;i++){
const item=G.currentDisplayPalette[i];
const c=document.createElement('div');
c.className='card3d';
c.style.cssText=`width:${CW}px;height:${CH}px;left:calc(50% - ${CW/2}px);top:calc(50% - ${CH/2}px);z-index:${i+1};transform:translateX(0) translateY(60px) rotate(0deg) scale(.8);opacity:0;transition:transform .55s cubic-bezier(.4,0,.2,1) ${i*.12}s, opacity .4s ${i*.12}s`;

let badge='';
if(item.type==='strong'){
  badge=`<span style="font-size:9px;background:rgba(255,255,255,0.2);padding:2px 6px;border-radius:4px;color:rgba(255,255,255,.8)">강 ${i+1}/2</span>`;
}else if(item.type==='blend'){
  badge=`<span style="font-size:9px;background:rgba(255,255,255,0.3);padding:2px 6px;border-radius:4px;color:#fff;font-weight:600">균형</span>`;
}else{
  badge=`<span style="font-size:9px;background:rgba(255,255,255,0.2);padding:2px 6px;border-radius:4px;color:rgba(255,255,255,.8)">약 ${i-2}/2</span>`;
}

const borderStyle=item.type==='blend'
  ?'border:2px solid rgba(255,255,255,0.5);'
  :'border:1px solid rgba(255,255,255,.15);';

c.innerHTML=`<div class="card-face" style="background:${item.color};${borderStyle}">
<span style="font-size:10px;font-family:monospace;color:rgba(255,255,255,.7)">${item.color}</span>
<div style="text-align:center">
<div style="width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.3);margin:0 auto 6px"></div>
<p style="font-size:11px;color:rgba(255,255,255,.95);line-height:1.4;word-break:keep-all">${item.desc}</p>
</div>
<p style="text-align:right">${badge}</p>
</div>`;

const capI=i;const capCol=item.color;const capDesc=item.desc;
c.onclick=()=>selectPaletteColor(capCol,capDesc,capI,c);
area.appendChild(c);cards.push(c);
}

requestAnimationFrame(()=>{requestAnimationFrame(()=>{
cards.forEach((c,i)=>{
c.style.transform=`translateX(${finalX[i]}px) translateY(0) rotate(${angles[i]}deg) scale(1)`;
c.style.opacity='1';
});
setTimeout(()=>selectPaletteColor(G.currentDisplayPalette[2].color,G.currentDisplayPalette[2].desc,2,cards[2]),900);
})});
